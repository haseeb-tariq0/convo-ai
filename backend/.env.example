APP_ENV=development
LOG_LEVEL=INFO

# Single shared bearer token for admin endpoints. Rotate before any non-dev use.
ADMIN_TOKEN=dev-admin-token-change-me

# Supabase — required.
# URL is public (printed in the dashboard). Service-role key is the admin-grade
# secret; copy it from Project Settings → API → `service_role` `secret`.
SUPABASE_URL=https://wwpkjayzddjzrvewakue.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set to "true" to fall back to the legacy in-memory store. Useful
# for offline dev or running tests without hitting Supabase. The repo's
# pytest suite sets this automatically via a fixture.
USE_IN_MEMORY_STORE=false

# Mock toggles — leave true until live integrations land. Flipping any to
# false requires the matching credentials below.
USE_MOCK_AI=true
USE_MOCK_SHEETS=true
USE_MOCK_GA4=true

# When USE_MOCK_AI=false, which provider gets called. "openai" is the
# default per Mohsin's May 20 "use any model, save on cost" guidance.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
